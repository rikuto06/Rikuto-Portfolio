---
import { ViewTransitions } from 'astro:transitions';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import '@/styles/global.css';

interface Props {
  tabName?: string;
}

const { tabName } = Astro.props;

function getDefaultTabName(pathname: string): string {
  if (pathname === '/') return 'Home.rkt';
  if (pathname === '/about' || pathname === '/about/') return 'about.rkt';
  if (pathname === '/works' || pathname === '/works/') return 'works.rkt';
  const segments = pathname.replace(/\/$/, '').split('/');
  const last = segments[segments.length - 1];
  return `${last}.rkt`;
}

const displayTab = tabName ?? getDefaultTabName(Astro.url.pathname);
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="中尾陸人のポートフォリオサイトです。">
    <link rel="icon" type="image/png" href="/images/fabicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Antonio:wght@100..700&family=IBM+Plex+Sans:ital,wght@0,100..700;1,100..700&family=Libre+Barcode+128&family=Zen+Kaku+Gothic+New:wght@300;400;500;700;900&display=swap"
      rel="stylesheet"
    />
    <meta name="generator" content={Astro.generator} />
    <title>Rikuto-Portfolio</title>
    <ViewTransitions />
  </head>
  <body class="bg-[#181818] font-zen md:pl-[5%]">
    <div class="flex h-dvh">
      <Header />
      <div class="flex w-full flex-col">
        <div class="hidden bg-[#181818] md:flex">
          <div
            class="font-ibm flex h-[3.61vw] max-h-13 w-[15.07vw] max-w-54.25 items-center overflow-hidden border-t-2 border-r border-[#A9A5A5]/20 border-t-[#0078D4] bg-[#1F1F1F] px-4 text-sm text-white text-ellipsis whitespace-nowrap"
          >
            {displayTab}
          </div>
        </div>
        <main
          class="flex-1 overflow-scroll bg-[#1F1F1F] px-4 pt-14 pb-10 md:pt-20.25 md:pr-[11%] md:pb-20 md:pl-[8.82%]"
        >
          <slot />
        </main>
        <Footer />
      </div>
    </div>
  </body>
</html>
