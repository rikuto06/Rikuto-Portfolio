---
import { ViewTransitions } from 'astro:transitions';
import Header from "@/components/Header.astro"
import Footer from "@/components/Footer.astro"

interface Props {
	tabName?: string;
}

const { tabName } = Astro.props;

// URLから自動推定
function getDefaultTabName(pathname: string): string {
	if (pathname === '/') return 'Home.rkt';
	if (pathname === '/about' || pathname === '/about/') return 'about.rkt';
	if (pathname === '/works' || pathname === '/works/') return 'works.rkt';
	// 動的ページはpropsで渡す想定
	const segments = pathname.replace(/\/$/, '').split('/');
	const last = segments[segments.length - 1];
	return `${last}.rkt`;
}

const displayTab = tabName ?? getDefaultTabName(Astro.url.pathname);
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Antonio:wght@100..700&family=Zen+Kaku+Gothic+New:wght@300;400;500;700;900&display=swap" rel="stylesheet" />
		<link rel="stylesheet" href="/src/styles/global.css">
		<meta name="generator" content={Astro.generator} />
		<title>Astro Basics</title>
		<ViewTransitions />
	</head>
	<body class="bg-[#181818] md:pl-[5%] ">
		<div class="flex h-screen">
			<Header />
			<div class="flex flex-col w-full">
				<div class="hidden md:flex bg-[#181818]">
					<div class="flex items-center w-[15.07vw] h-[3.61vw] max-w-54.25 max-h-13 px-4 bg-[#1F1F1F] text-white text-sm border-r border-[#A9A5A5]/20 border-t-2 border-t-[#0078D4] whitespace-nowrap overflow-hidden text-ellipsis">
						{displayTab}
					</div>
				</div>
				<main class="flex-1 overflow-scroll bg-[#1F1F1F] pt-14 px-4 pb-10 md:pt-20.25 md:pb-20 md:pl-[8.82%] md:pr-[11%]">
					<slot />
				</main>
				<Footer />
			</div>
		</div>
	</body>
</html>
