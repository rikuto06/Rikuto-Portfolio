---
import { ViewTransitions } from 'astro:transitions';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import '@/styles/global.css';

interface Props {
  tabName?: string;
}

const { tabName } = Astro.props;

function getDefaultTabName(pathname: string): string {
  if (pathname === '/') return 'Home.rkt';
  if (pathname === '/about' || pathname === '/about/') return 'about.rkt';
  if (pathname === '/works' || pathname === '/works/') return 'works.rkt';
  const segments = pathname.replace(/\/$/, '').split('/');
  const last = segments[segments.length - 1];
  return `${last}.rkt`;
}

const displayTab = tabName ?? getDefaultTabName(Astro.url.pathname);
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Antonio:wght@100..700&family=IBM+Plex+Sans:ital,wght@0,100..700;1,100..700&family=Libre+Barcode+128&family=Zen+Kaku+Gothic+New:wght@300;400;500;700;900&display=swap"
      rel="stylesheet"
    />
    <meta name="generator" content={Astro.generator} />
    <title>Astro Basics</title>
    <ViewTransitions />
    <script is:inline>
      function applyTheme() {
        const theme = localStorage.getItem('theme');
        if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      }
      applyTheme();
      document.addEventListener('astro:after-swap', applyTheme);
    </script>
  </head>
  <body class="font-zen bg-background md:pl-[5%]">
    <!-- Dark/Light mode toggle switch -->
    <button
      id="theme-toggle"
      class="fixed top-3 right-3 z-50 flex h-8 w-14 items-center rounded-full bg-foreground/10 p-1 transition-colors duration-300 hover:bg-foreground/20"
      aria-label="テーマ切り替え"
    >
      <span class="flex h-6 w-6 items-center justify-center rounded-full bg-background shadow-sm transition-transform duration-300 dark:translate-x-6">
        <svg class="h-3.5 w-3.5 text-foreground transition-opacity duration-300 dark:opacity-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"></circle>
          <line x1="12" y1="1" x2="12" y2="3"></line>
          <line x1="12" y1="21" x2="12" y2="23"></line>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
          <line x1="1" y1="12" x2="3" y2="12"></line>
          <line x1="21" y1="12" x2="23" y2="12"></line>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
        </svg>
        <svg class="absolute h-3.5 w-3.5 text-foreground opacity-0 transition-opacity duration-300 dark:opacity-100" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </span>
    </button>

    <div class="flex h-screen">
      <Header />
      <div class="flex w-full flex-col">
        <div class="hidden bg-background md:flex">
          <div
            class="font-ibm flex h-[3.61vw] max-h-13 w-[15.07vw] max-w-54.25 items-center overflow-hidden border-t-2 border-r border-border border-t-[#0078D4] bg-card px-4 text-sm text-ellipsis whitespace-nowrap text-foreground"
          >
            {displayTab}
          </div>
        </div>
        <main
          class="flex-1 overflow-scroll bg-card px-4 pt-14 pb-10 md:pt-20.25 md:pr-[11%] md:pb-20 md:pl-[8.82%]"
        >
          <slot />
        </main>
        <Footer />
      </div>
    </div>
    <script>
      function initThemeToggle() {
        const toggle = document.getElementById('theme-toggle');
        if (!toggle) return;
        toggle.addEventListener('click', () => {
          const isDark = document.documentElement.classList.toggle('dark');
          localStorage.setItem('theme', isDark ? 'dark' : 'light');
        });
      }
      document.addEventListener('astro:page-load', initThemeToggle);
    </script>
  </body>
</html>
