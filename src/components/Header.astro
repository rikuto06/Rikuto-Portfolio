<script>
    function initDetails() {
        const detailsElements = document.querySelectorAll<HTMLDetailsElement>('details[id]');
        
        detailsElements.forEach((details) => {
            const saved = localStorage.getItem(details.id);
            if (saved === 'open') {
                details.open = true;
            }
        });

        detailsElements.forEach((details) => {
            details.addEventListener('toggle', () => {
                localStorage.setItem(details.id, details.open ? 'open' : 'closed');
            });
        });
    }

    // 初回読み込み
    document.addEventListener('DOMContentLoaded', initDetails);
    
    // View Transitions使用時のページ遷移後
    document.addEventListener('astro:page-load', initDetails);
</script>