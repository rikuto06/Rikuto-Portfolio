---
import { getCollection } from 'astro:content';
const posts = await getCollection('blog');
const works = await getCollection('works');

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'about' },
];
---

<button
  type="button"
  id="drawer-toggle"
  class="group fixed top-3 left-3 z-50 flex h-10 w-10 flex-col items-center justify-center gap-1.5 md:hidden"
  aria-label="メニューを開く"
>
  <span
    class="block h-px w-6 origin-center bg-white transition-all duration-300 group-data-open:translate-y-1.75 group-data-open:rotate-45"
  ></span>
  <span
    class="block h-px w-6 origin-center bg-white transition-all duration-300 group-data-open:opacity-0"
  ></span>
  <span
    class="block h-px w-6 origin-center bg-white transition-all duration-300 group-data-open:-translate-y-1.75 group-data-open:-rotate-45"
  ></span>
</button>

<div
  id="drawer-overlay"
  class="pointer-events-none fixed inset-0 z-30 bg-black/50 opacity-0 transition-opacity duration-300 md:hidden"
>
</div>

<header
  id="header-drawer"
  transition:persist
  class="font-ibm fixed top-0 left-0 z-40 flex h-full w-[75%] max-w-75 -translate-x-full flex-col overflow-y-auto border-r-[0.2px] border-r-[#A9A5A5] bg-[#181818] pt-14 pl-8 text-[1.25rem] transition-transform duration-300 ease-in-out md:static md:z-auto md:w-[30%] md:max-w-none md:translate-x-0 md:pt-13 [&_a]:block [&_a]:w-full [&_a]:px-2 [&_a]:py-0.5 [&_a]:no-underline [&_a]:transition-colors [&_a]:duration-100 [&_a:hover]:bg-white/10 [&_a:hover]:no-underline [&_summary]:flex [&_summary]:cursor-pointer [&_summary]:list-none [&_summary]:items-center [&_summary::-webkit-details-marker]:hidden"
>
  <a href="/" class="md:text-[1.25rem]">RIKUTO NAKAO</a>
  <details class="group/main" id="main-details" open>
    <summary class="mt-2 md:mt-0"
      ><img
        class="mr-1 h-2.5 w-2.5 -rotate-90 transition-transform duration-200 group-open/main:rotate-0"
        src="/images/Vector.svg"
        alt=""
      />my-portfolio</summary
    >
    {
      navLinks.map((link) => (
        <a class="mt-2 flex! items-center gap-1 md:mt-0" href={link.href}>
          <img src="/images/file.svg" alt="" />
          {link.label}.rkt
        </a>
      ))
    }
    <details class="group/works" id="works-details">
      <summary class="mt-2 md:mt-0"
        ><img
          class="mr-1 h-2.5 w-2.5 -rotate-90 transition-transform duration-200 group-open/works:rotate-0"
          src="/images/Vector.svg"
          alt=""
        /><a href="/works">WORKS</a></summary
      >
      {
        works.map((work) => (
          <a class="mt-2 flex! items-center gap-1 md:mt-0" href={`/works/${work.id}`}>
            <img src="/images/file.svg" alt="" />
            {work.data.title}.rkt
          </a>
        ))
      }
    </details>
    <details class="group/blogs" id="blogs-details">
      <summary
        ><img
          class="mr-1 h-2.5 w-2.5 -rotate-90 transition-transform duration-200 group-open/blogs:rotate-0"
          src="/images/Vector.svg"
          alt=""
        />Blogs</summary
      >
      {
        posts.map((post) => (
          <a class="flex! items-center gap-1 text-[0.8rem]" href={`/blog/${post.id}`}>
            <img src="/images/file.svg" alt="" />
            {post.data.title}.rkt
          </a>
        ))
      }
    </details>
  </details>
</header>

<script>
  let drawerAbort: AbortController | null = null;

  function initDetails() {
    const detailsElements = document.querySelectorAll<HTMLDetailsElement>('details[id]');

    detailsElements.forEach((details) => {
      const saved = localStorage.getItem(details.id);
      if (saved === 'open') {
        details.open = true;
      }
    });

    detailsElements.forEach((details) => {
      details.addEventListener('toggle', () => {
        localStorage.setItem(details.id, details.open ? 'open' : 'closed');
      });
    });
  }

  function initDrawer() {
    if (drawerAbort) drawerAbort.abort();
    drawerAbort = new AbortController();
    const signal = drawerAbort.signal;

    const toggle = document.getElementById('drawer-toggle');
    const overlay = document.getElementById('drawer-overlay');
    const drawer = document.getElementById('header-drawer');

    if (!toggle || !overlay || !drawer) return;

    delete toggle.dataset.open;
    drawer.classList.add('-translate-x-full');
    drawer.classList.remove('translate-x-0');
    overlay.classList.add('opacity-0', 'pointer-events-none');
    overlay.classList.remove('opacity-100', 'pointer-events-auto');
    document.body.classList.remove('overflow-hidden');

    function openDrawer() {
      toggle!.dataset.open = '';
      drawer!.classList.remove('-translate-x-full');
      drawer!.classList.add('translate-x-0');
      overlay!.classList.remove('opacity-0', 'pointer-events-none');
      overlay!.classList.add('opacity-100', 'pointer-events-auto');
      document.body.classList.add('overflow-hidden');
    }

    function closeDrawer() {
      delete toggle!.dataset.open;
      drawer!.classList.add('-translate-x-full');
      drawer!.classList.remove('translate-x-0');
      overlay!.classList.add('opacity-0', 'pointer-events-none');
      overlay!.classList.remove('opacity-100', 'pointer-events-auto');
      document.body.classList.remove('overflow-hidden');
    }

    toggle.addEventListener(
      'click',
      () => {
        const isOpen = drawer.classList.contains('translate-x-0');
        isOpen ? closeDrawer() : openDrawer();
      },
      { signal },
    );

    overlay.addEventListener('click', closeDrawer, { signal });

    drawer.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeDrawer, { signal });
    });
  }

  function init() {
    initDetails();
    initDrawer();
  }

  document.addEventListener('astro:page-load', init);
</script>
