<footer
  class="font-ibm h-auto w-full border-amber-50 px-4 md:h-50 md:px-0  md:pr-[11%] md:pl-[8.82%]"
>
  <div class="mt-4 flex justify-between md:mt-8.5">
    <p>dev</p><p>and</p><p>design</p>
  </div>
  <div class="mt-6 flex justify-between md:mt-15">
    <div>
      <dl class="mt-2">
        <dt>GitHub</dt>
        <dd class="break-all">
          <a href="https://github.com/rikuto06" target="_blank">https://github.com/rikuto06</a>
        </dd>
        <small>&copy;2026 RIKUTO NAKAO</small>
      </dl>
    </div>
    <div class="font-ibm flex flex-col">
      <p class="text-[0.875rem]">DESIGN BY RIKUTO</p>
      <p class="flex justify-between">
        <span>JP</span>
        <span><span id="footer-time" transition:persist></span> JST</span>
      </p>
      <div class="font-barcode text-[2.625rem]">portfolio</div>
    </div>
  </div>
</footer>

<script>
  let timeInterval: ReturnType<typeof setInterval> | undefined;

  function initClock() {
    clearInterval(timeInterval);
    function updateTime() {
      const now = new Date();
      const hours = String(now.getHours()).padStart(2, '0');
      const minutes = String(now.getMinutes()).padStart(2, '0');
      const el = document.getElementById('footer-time');
      if (el) el.textContent = `${hours}:${minutes}`;
    }
    updateTime();
    timeInterval = setInterval(updateTime, 1000);
  }

  document.addEventListener('astro:page-load', initClock);
</script>
