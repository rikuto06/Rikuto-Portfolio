---
const Skl = [
  {
    Head: 'LANGUAGES / FRAMEWORKS',
    Skills: 'HTML / CSS / JavaScript / TypeScript / PHP / Next.js / Astro / Tailwind CSS / GSAP',
    Text: 'HTML、CSS、JavaScript(TypeScript)を使って静的なWebサイトのコーディングができます。セマンティックなコーディングや、アクセシビリティへの配慮、モダンな技術等、常にキャッチアップし続けることを心がけています。',
  },
  {
    Head: 'CMS',
    Skills: 'WordPress / microCMS',
    Text: 'WordPressを使ったサイト構築が可能です。またモダンなヘッドレスCMSを使ったブログサイト構築なども学習しています。',
  },
  {
    Head: 'TOOLS',
    Skills: 'Git / GitHub / VSCode / Figma / Illustrator / Photoshop / Notion',
    Text: 'コーディングエディターはVS Codeを使用しています。作ったコードはGitで管理し、日々学習したコードはGitHub上に記録するようにしています。デザインカンプは主にFigmaを使用しています。',
  },
];
---

<section class="mt-16 md:mt-32">
  <h3 class="font-ibm text-[2rem] md:text-[3rem]" data-scramble="SKILLS">SKILLS</h3>
  <ul>
    {
      Skl.map((item, i) => (
        <li class:list={[i > 0 && 'mt-8 md:mt-15']}>
          <h3 class="mt-3 text-[1.5rem] md:text-[2rem]">{item.Head}</h3>
          <p class="mt-3 md:text-[1.25rem]">{item.Skills}</p>
          <p class="mt-3 leading-[200%]">{item.Text}</p>
        </li>
      ))
    }
  </ul>
</section>
