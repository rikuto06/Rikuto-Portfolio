---
import { Image } from 'astro:assets';
import soccerImg from '@/assets/soccer.JPG';
import southernImg from '@/assets/Southern.JPG';

const FAVORITES = [
  {
    image: soccerImg,
    title: 'サッカー',
    description:
      '小学生〜大学生までプレーしました。大怪我をして辞めてしまいましたが、今も遊び感覚ではありますが友人のチームの助っ人等でプレーしたりしています！',
  },
  {
    image: southernImg,
    title: 'サザンオールスターズ',
    description: '中学生の時からずっとサザンの大ファンです!!!',
  },
  {
    image: southernImg,
    title: 'ヘアメイク',
    description: '美容師の資格等切持っていませんが、ヘアセットなどが得意です。',
  },
];
---

<section class="mt-16 md:mt-32">
  <h3 class="font-ibm text-[2rem] md:text-[3rem]">OFF THE PITCH</h3>
  <div class="mt-10 md:mt-20 md:ml-80 md:grid md:grid-cols-2 md:gap-0 md:gap-y-6">
    {
      FAVORITES.map((favorite, i) => (
        <div
          class:list={[
            'group relative aspect-square w-full cursor-pointer overflow-hidden md:size-60',
            i > 0 && 'mt-8 md:mt-0',
          ]}
        >
          <Image src={favorite.image} alt="" class="h-full w-full object-cover" />
          <div class="absolute inset-0 flex flex-col items-center justify-center bg-gray-800/60 px-3 opacity-0 transition-opacity duration-300 group-hover:opacity-100">
            <div class="text-xl font-bold text-white">{favorite.title}</div>
            <p class="mt-1.5 text-sm md:text-base">{favorite.description}</p>
          </div>
        </div>
      ))
    }
  </div>
</section>
